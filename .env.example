# LLM API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# BGE Embedding
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_DIM=1024

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=rag_knowledge_base

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SESSION_TTL=86400

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Retrieval Weights (三路融合)
VECTOR_WEIGHT=0.5
KEYWORD_WEIGHT=0.25
GRAPH_WEIGHT=0.25

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
